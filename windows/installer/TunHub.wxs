<?xml version="1.0" encoding="utf-8"?>
<!-- TunHub for Windows — MSI package (WiX v5). Build on Windows only:
       wix build installer\TunHub.wxs -ext WixToolset.UI.wixext -ext WixToolset.Util.wixext ^
                 -d DistDir=dist\TunHub -o dist\TunHub-0.8.1.msi
     DistDir is the publish output from build.ps1 (WinUI app + helper + bundled cores). -->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="TunHub"
           Manufacturer="TunHub"
           Version="0.8.1.0"
           UpgradeCode="7E3B9A54-0C2F-4E7A-9C1B-9B0F0A2D6E11"
           Scope="perMachine"
           Compressed="yes">

    <!-- In-place upgrade: remove the old version early (so running files aren't locked), and
         allow re-installing the same version (handy for dev rebuilds). -->
    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  Schedule="afterInstallInitialize"
                  DowngradeErrorMessage="A newer version of TunHub is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="TunHubIcon" SourceFile="$(var.DistDir)\Assets\TunHub.ico" />
    <Property Id="ARPPRODUCTICON" Value="TunHubIcon" />

    <!-- Close a running TunHub before install/upgrade so its files aren't in use. The tray keeps
         the process alive after the window is closed, so terminate it if it doesn't exit. -->
    <util:CloseApplication Id="CloseTunHub"
                           Target="TunHub.exe"
                           CloseMessage="yes"
                           TerminateProcess="0"
                           RebootPrompt="no"
                           Description="TunHub is running. Setup will close it to continue." />

    <!-- Installer UI with a folder-selection page. -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="installer\license.rtf" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="TunHub" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutFolder" Name="TunHub" />
    </StandardDirectory>

    <!-- Harvest the publish output (everything except the helper exe, which is a service). -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.DistDir)\**">
        <Exclude Files="$(var.DistDir)\tunhub-helper.exe" />
      </Files>

      <Component Id="HelperService" Guid="8A1D2C33-5F44-4B66-8E77-1A2B3C4D5E6F">
        <File Id="HelperExe" Source="$(var.DistDir)\tunhub-helper.exe" KeyPath="yes" />
        <!-- Privileged background service (LocalSystem) — macOS root LaunchDaemon equivalent. -->
        <ServiceInstall Id="TunHubHelperInstall"
                        Name="TunHubHelper"
                        DisplayName="TunHub Helper"
                        Description="Privileged tunnel manager for TunHub (WireGuard / AmneziaWG / OpenVPN)."
                        Type="ownProcess"
                        Start="auto"
                        ErrorControl="normal"
                        Account="LocalSystem" />
        <ServiceControl Id="TunHubHelperControl"
                        Name="TunHubHelper"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="AppShortcuts" Directory="AppShortcutFolder">
      <Component Id="AppShortcut" Guid="C9F0E1D2-3A4B-4C5D-8E6F-70819A2B3C4D">
        <Shortcut Id="TunHubShortcut"
                  Name="TunHub"
                  Target="[INSTALLFOLDER]TunHub.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="TunHubIcon" />
        <RemoveFolder Id="RemoveAppShortcutFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\TunHub" Name="installed" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Feature Id="Main" Title="TunHub" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="AppShortcuts" />
    </Feature>
  </Package>
</Wix>
