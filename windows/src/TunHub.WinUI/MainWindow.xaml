<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="TunHub.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TunHub.WinUI">

  <Grid x:Name="Root" Padding="12" RowSpacing="10"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Toolbar -->
    <Grid Grid.Row="0" ColumnSpacing="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <Ellipse x:Name="HelperDot" Width="10" Height="10" Fill="Gray" />
        <TextBlock x:Name="HelperStatus" VerticalAlignment="Center"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="…" />
      </StackPanel>
      <Button Grid.Column="1" x:Name="ImportBtn" Content="Import…" />
      <Button Grid.Column="2" x:Name="StopAllBtn" Content="Stop all" />
      <Button Grid.Column="3" x:Name="SettingsBtn" Content="Settings" />
    </Grid>

    <!-- Body -->
    <Grid Grid.Row="1" ColumnSpacing="12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="300" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" CornerRadius="8" BorderThickness="1"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
        <ListView x:Name="TunnelList" SelectionMode="Single" Padding="4">
          <ListView.ItemTemplate>
            <DataTemplate>
              <Grid ColumnSpacing="10" Padding="4">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center"
                         Fill="{Binding StatusBrush}" />
                <StackPanel Grid.Column="1">
                  <TextBlock Text="{Binding Name}" />
                  <TextBlock Text="{Binding StatusText}" FontSize="11"
                             Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Border>

      <ScrollViewer Grid.Column="1">
        <StackPanel x:Name="DetailPanel" Spacing="10">
          <TextBlock x:Name="EmptyHint"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     Text="No tunnels — import a .conf or ZIP" />
          <TextBlock x:Name="DetailName" FontSize="24" FontWeight="SemiBold" />
          <TextBlock x:Name="DetailKind" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Ellipse x:Name="DetailDot" Width="12" Height="12" VerticalAlignment="Center" Fill="Gray" />
            <TextBlock x:Name="DetailStatus" VerticalAlignment="Center" />
          </StackPanel>
          <TextBlock x:Name="DetailTraffic"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="StartBtn" Content="Start" Style="{ThemeResource AccentButtonStyle}" />
            <Button x:Name="StopBtn" Content="Stop" />
            <Button x:Name="DeleteBtn" Content="Delete" />
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</Window>
