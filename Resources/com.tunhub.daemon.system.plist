<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key><string>com.tunhub.daemon</string>
    <key>Program</key><string>/Applications/TunHub.app/Contents/MacOS/tunhubd</string>
    <key>MachServices</key>
    <dict>
        <key>com.tunhub.daemon.xpc</key><true/>
    </dict>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key><false/>
    </dict>
    <key>RunAtLoad</key><true/>
    <key>ProcessType</key><string>Interactive</string>
    <key>StandardErrorPath</key><string>/var/log/tunhub-daemon.stderr.log</string>
</dict>
</plist>
